# corrigir_duplicatas_restantes.py
"""
CORREÇÃO FINAL: Remove as 71 duplicatas restantes
Garante que não apareçam textos repetidos nos simulados
"""

import psycopg2
import hashlib

def corrigir_todas_duplicatas():
    """Remove TODAS as duplicatas do banco definitivamente"""
    
    print("🔧 CORRIGINDO TODAS AS DUPLICATAS RESTANTES")
    print("=" * 50)
    
    try:
        conn = psycopg2.connect(
            host='localhost',
            user='postgres',
            password='1469',
            database='launcher_db'
        )
        
        cursor = conn.cursor()
        
        # Encontrar TODAS as duplicatas por texto
        print("1️⃣ Identificando todas as duplicatas...")
        
        cursor.execute("""
            SELECT texto, COUNT(*) as total, 
                   string_agg(id::text, ',' ORDER BY id) as todos_ids,
                   MIN(id) as id_manter
            FROM questoes_base 
            WHERE ativa = true AND texto IS NOT NULL AND texto != ''
            GROUP BY texto 
            HAVING COUNT(*) > 1
            ORDER BY COUNT(*) DESC
        """)
        
        duplicatas = cursor.fetchall()
        
        if not duplicatas:
            print("✅ Nenhuma duplicata encontrada!")
            cursor.close()
            conn.close()
            return True
        
        print(f"📊 Encontradas {len(duplicatas)} grupos de duplicatas")
        
        total_removidas = 0
        
        for i, (texto, total, todos_ids, id_manter) in enumerate(duplicatas, 1):
            ids_lista = [int(x.strip()) for x in todos_ids.split(',')]
            ids_remover = [x for x in ids_lista if x != id_manter]
            
            print(f"\n📝 Grupo {i}: {total} duplicatas")
            print(f"   Texto: {texto[:80]}...")
            print(f"   Mantendo ID: {id_manter}")
            print(f"   Removendo: {len(ids_remover)} duplicatas")
            
            # Desativar todas as duplicatas exceto a primeira
            for id_remover in ids_remover:
                cursor.execute("""
                    UPDATE questoes_base 
                    SET ativa = false,
                        texto = CONCAT('[DUPLICATA REMOVIDA] ', texto)
                    WHERE id = %s
                """, (id_remover,))
                
                total_removidas += 1
        
        # Commit das mudanças
        conn.commit()
        
        print(f"\n✅ {total_removidas} questões duplicadas removidas!")
        
        # Verificar resultado
        cursor.execute("""
            SELECT COUNT(*) 
            FROM (
                SELECT texto 
                FROM questoes_base 
                WHERE ativa = true 
                GROUP BY texto 
                HAVING COUNT(*) > 1
            ) as ainda_duplicadas
        """)
        
        duplicatas_restantes = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM questoes_base WHERE ativa = true")
        total_ativas = cursor.fetchone()[0]
        
        print(f"📊 Questões ativas finais: {total_ativas}")
        print(f"📊 Duplicatas restantes: {duplicatas_restantes}")
        
        cursor.close()
        conn.close()
        
        return duplicatas_restantes == 0
        
    except Exception as e:
        print(f"❌ Erro na correção: {e}")
        return False

def otimizar_banco():
    """Otimiza o banco após remoção de duplicatas"""
    
    print("\n🔧 OTIMIZANDO BANCO DE DADOS")
    print("=" * 50)
    
    try:
        conn = psycopg2.connect(
            host='localhost',
            user='postgres',
            password='1469',
            database='launcher_db'
        )
        
        cursor = conn.cursor()
        
        # Atualizar estatísticas da tabela
        print("1️⃣ Atualizando estatísticas...")
        cursor.execute("ANALYZE questoes_base")
        
        # Limpar espaço não utilizado
        print("2️⃣ Limpando espaço...")
        cursor.execute("VACUUM questoes_base")
        
        # Reindexar se necessário
        print("3️⃣ Otimizando índices...")
        cursor.execute("REINDEX TABLE questoes_base")
        
        conn.commit()
        
        print("✅ Banco otimizado!")
        
        cursor.close()
        conn.close()
        
        return True
        
    except Exception as e:
        print(f"❌ Erro na otimização: {e}")
        return False

def testar_sistema_apos_correcao():
    """Testa se o sistema está funcionando após correções"""
    
    print("\n🧪 TESTANDO SISTEMA APÓS CORREÇÃO")
    print("=" * 50)
    
    try:
        import sys
        sys.path.insert(0, '.')
        
        # Limpar cache de imports
        modules_to_remove = [m for m in sys.modules.keys() if 'app.services' in m]
        for module in modules_to_remove:
            del sys.modules[module]
        
        from app.services.gerador_questoes import gerar_questoes_simulado, obter_relatorio_disponibilidade
        
        print("1️⃣ Testando disponibilidade...")
        disp = obter_relatorio_disponibilidade()
        
        if not disp:
            print("❌ Nenhuma questão disponível!")
            return False
        
        print(f"✅ {sum(disp.values())} questões disponíveis em {len(disp)} matérias")
        
        # Mostrar distribuição
        print("\n📊 Distribuição por matéria:")
        for materia, count in sorted(disp.items(), key=lambda x: x[1], reverse=True)[:10]:
            print(f"   {materia}: {count}")
        
        print("\n2️⃣ Testando geração de questões...")
        
        # Testar com Matemática (agora tem 92 questões)
        if 'Matemática' in disp and disp['Matemática'] > 0:
            questoes_mat = gerar_questoes_simulado(['Matemática'], 5, 'equilibrada')
            
            if questoes_mat:
                print(f"✅ {len(questoes_mat)} questões de Matemática geradas!")
                
                # Verificar se há textos duplicados
                textos = [q['texto'] for q in questoes_mat]
                textos_unicos = set(textos)
                
                if len(textos) == len(textos_unicos):
                    print("✅ Nenhum texto duplicado nas questões geradas!")
                else:
                    print(f"⚠️ {len(textos) - len(textos_unicos)} textos duplicados encontrados")
                
                # Mostrar exemplo
                exemplo = questoes_mat[0]
                print(f"\n📝 Exemplo de questão:")
                print(f"   Matéria: {exemplo['materia']}")
                print(f"   Texto: {exemplo['texto'][:100]}...")
                print(f"   Resposta: {exemplo['resposta_correta']}")
                
            else:
                print("❌ Falha ao gerar questões de Matemática")
                return False
        
        # Testar simulado misto
        print("\n3️⃣ Testando simulado misto...")
        areas_teste = ['Matemática', 'Física', 'História']
        areas_disponiveis = [a for a in areas_teste if a in disp and disp[a] > 0]
        
        if areas_disponiveis:
            questoes_mistas = gerar_questoes_simulado(areas_disponiveis, 10, 'equilibrada')
            
            if questoes_mistas:
                print(f"✅ {len(questoes_mistas)} questões mistas geradas!")
                
                # Verificar distribuição
                materias_geradas = {}
                for q in questoes_mistas:
                    materia = q['materia']
                    materias_geradas[materia] = materias_geradas.get(materia, 0) + 1
                
                print("   Distribuição:")
                for materia, count in materias_geradas.items():
                    print(f"     {materia}: {count}")
                
                # Verificar duplicatas
                textos_mistas = [q['texto'] for q in questoes_mistas]
                if len(textos_mistas) == len(set(textos_mistas)):
                    print("✅ Nenhuma duplicata no simulado misto!")
                    return True
                else:
                    print("⚠️ Ainda há duplicatas no simulado")
                    return False
            else:
                print("❌ Falha ao gerar simulado misto")
                return False
        else:
            print("⚠️ Nenhuma área disponível para teste misto")
            return True
        
    except Exception as e:
        print(f"❌ Erro no teste: {e}")
        import traceback
        print(f"Traceback: {traceback.format_exc()}")
        return False

def relatorio_final():
    """Gera relatório final das correções"""
    
    print("\n📊 RELATÓRIO FINAL DAS CORREÇÕES")
    print("=" * 50)
    
    try:
        conn = psycopg2.connect(
            host='localhost',
            user='postgres',
            password='1469',
            database='launcher_db'
        )
        
        cursor = conn.cursor()
        
        # Estatísticas finais
        cursor.execute("SELECT COUNT(*) FROM questoes_base WHERE ativa = true")
        total_ativas = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM questoes_base WHERE ativa = false")
        total_inativas = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(DISTINCT materia) FROM questoes_base WHERE ativa = true")
        total_materias = cursor.fetchone()[0]
        
        cursor.execute("""
            SELECT COUNT(*) 
            FROM (
                SELECT texto 
                FROM questoes_base 
                WHERE ativa = true 
                GROUP BY texto 
                HAVING COUNT(*) > 1
            ) as duplicatas
        """)
        duplicatas_finais = cursor.fetchone()[0]
        
        print(f"📊 ESTATÍSTICAS FINAIS:")
        print(f"   Questões ativas: {total_ativas}")
        print(f"   Questões inativas: {total_inativas}")
        print(f"   Matérias cobertas: {total_materias}")
        print(f"   Duplicatas restantes: {duplicatas_finais}")
        
        # Capacidade de simulados
        simulados_enem = total_ativas // 180
        simulados_medios = total_ativas // 45
        
        print(f"\n🎯 CAPACIDADE DE SIMULADOS:")
        print(f"   ENEM completos (180q): ~{simulados_enem}")
        print(f"   Simulados médios (45q): ~{simulados_medios}")
        
        # Top matérias
        cursor.execute("""
            SELECT materia, COUNT(*) 
            FROM questoes_base 
            WHERE ativa = true 
            GROUP BY materia 
            ORDER BY COUNT(*) DESC
            LIMIT 10
        """)
        
        print(f"\n📚 TOP MATÉRIAS:")
        for materia, count in cursor.fetchall():
            print(f"   {materia}: {count}")
        
        cursor.close()
        conn.close()
        
        return duplicatas_finais == 0
        
    except Exception as e:
        print(f"❌ Erro no relatório: {e}")
        return False

def main():
    """Executa correção final das duplicatas"""
    
    print("🔧 CORREÇÃO FINAL DAS DUPLICATAS RESTANTES")
    print("="*60)
