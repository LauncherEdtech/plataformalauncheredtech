# investigar_problemas.py
"""
Investiga e corrige problemas da migração
"""

import psycopg2
import json
import os
from pathlib import Path

def conectar_banco():
    """Conecta ao PostgreSQL"""
    return psycopg2.connect(
        host='localhost',
        port=5432,
        user='postgres',
        password='1469',
        database='launcher_db'
    )

def investigar_arquivos_vazios():
    """Investiga arquivos que não tiveram questões processadas"""
    print("="*60)
    print("INVESTIGANDO ARQUIVOS 'VAZIOS'")
    print("="*60)
    
    arquivos_problematicos = [
        'EspanholData.txt',
        'InglesData.txt', 
        'LiteraturaData.txt',
        'MatematicaData.txt'
    ]
    
    for arquivo in arquivos_problematicos:
        if not os.path.exists(arquivo):
            print(f"[INFO] {arquivo} não existe")
            continue
        
        print(f"\n--- Investigando {arquivo} ---")
        
        try:
            with open(arquivo, 'r', encoding='utf-8') as f:
                conteudo = f.read()
            
            print(f"[INFO] Tamanho do arquivo: {len(conteudo)} caracteres")
            print(f"[INFO] Primeiros 200 caracteres:")
            print(repr(conteudo[:200]))
            
            # Tentar diferentes abordagens de parsing
            sucesso_json = False
            
            # Tentativa 1: JSON direto
            try:
                dados = json.loads(conteudo)
                print(f"[OK] JSON válido - {len(dados) if isinstance(dados, list) else 1} objetos")
                sucesso_json = True
            except:
                print("[INFO] Não é JSON válido direto")
            
            # Tentativa 2: Contar chaves por linha
            if not sucesso_json:
                linhas_com_question = [l for l in conteudo.split('\n') if 'question' in l.lower()]
                print(f"[INFO] Linhas com 'question': {len(linhas_com_question)}")
                
                if linhas_com_question:
                    print(f"[INFO] Primeira linha com question:")
                    print(repr(linhas_com_question[0][:100]))
            
            # Tentativa 3: Verificar se é array vs objetos separados
            abertura_chaves = conteudo.count('{')
            fechamento_chaves = conteudo.count('}')
            print(f"[INFO] Chaves: {abertura_chaves} aberturas, {fechamento_chaves} fechamentos")
            
        except Exception as e:
            print(f"[ERRO] Erro ao ler {arquivo}: {e}")

def corrigir_problema_varchar():
    """Investiga e corrige problema de VARCHAR(1) em resposta_correta"""
    print("\n" + "="*60)
    print("INVESTIGANDO PROBLEMA VARCHAR(1)")
    print("="*60)
    
    conn = conectar_banco()
    cursor = conn.cursor()
    
    # Buscar questões com resposta_correta problemática
    sql_investigar = """
    SELECT id, materia, resposta_correta, LENGTH(resposta_correta) as tamanho
    FROM questoes_base 
    WHERE LENGTH(resposta_correta) > 1
    ORDER BY id
    LIMIT 10
    """
    
    try:
        cursor.execute(sql_investigar)
        problemas = cursor.fetchall()
        
        if problemas:
            print(f"[PROBLEMA] Encontradas {len(problemas)} questões com resposta_correta > 1 caractere:")
            
            for id, materia, resposta, tamanho in problemas:
                print(f"  ID {id} ({materia}): '{resposta}' (tamanho: {tamanho})")
            
            # Tentar corrigir automaticamente
            print("\n[INFO] Tentando corrigir automaticamente...")
            
            sql_corrigir = """
            UPDATE questoes_base 
            SET resposta_correta = LEFT(UPPER(TRIM(resposta_correta)), 1)
            WHERE LENGTH(resposta_correta) > 1
            AND LEFT(UPPER(TRIM(resposta_correta)), 1) IN ('A', 'B', 'C', 'D', 'E')
            """
            
            cursor.execute(sql_corrigir)
            linhas_afetadas = cursor.rowcount
            conn.commit()
            
            print(f"[OK] {linhas_afetadas} questões corrigidas automaticamente")
            
            # Verificar se ainda há problemas
            cursor.execute(sql_investigar)
            problemas_restantes = cursor.fetchall()
            
            if problemas_restantes:
                print(f"[ATENÇÃO] Ainda há {len(problemas_restantes)} problemas:")
                for id, materia, resposta, tamanho in problemas_restantes:
                    print(f"  ID {id}: '{resposta}' - pode precisar correção manual")
            else:
                print("[OK] Todos os problemas de resposta_correta foram corrigidos!")
        
        else:
            print("[OK] Nenhum problema de VARCHAR encontrado")
    
    except Exception as e:
        print(f"[ERRO] Erro ao investigar VARCHAR: {e}")
    
    finally:
        cursor.close()
        conn.close()

def estatisticas_detalhadas():
    """Mostra estatísticas detalhadas do banco"""
    print("\n" + "="*60)
    print("ESTATÍSTICAS DETALHADAS")
    print("="*60)
    
    conn = conectar_banco()
    cursor = conn.cursor()
    
    try:
        # Total por matéria
        cursor.execute("""
            SELECT materia, COUNT(*) as total
            FROM questoes_base 
            GROUP BY materia 
            ORDER BY total DESC
        """)
        
        print("\n📊 Questões por Matéria:")
        total_geral = 0
        for materia, total in cursor.fetchall():
            print(f"  {materia}: {total} questões")
            total_geral += total
        
        print(f"\n📈 Total Geral: {total_geral} questões")
        
        # Verificar campos importantes
        cursor.execute("""
            SELECT 
                COUNT(*) as total,
                COUNT(CASE WHEN explicacao != '' THEN 1 END) as com_explicacao,
                COUNT(CASE WHEN topico != 'Não especificado' THEN 1 END) as com_topico,
                COUNT(CASE WHEN imagem_url != '' THEN 1 END) as com_imagem
            FROM questoes_base
        """)
        
        stats = cursor.fetchone()
        print(f"\n📋 Qualidade dos Dados:")
        print(f"  Total de questões: {stats[0]}")
        print(f"  Com explicação: {stats[1]} ({stats[1]/stats[0]*100:.1f}%)")
        print(f"  Com tópico: {stats[2]} ({stats[2]/stats[0]*100:.1f}%)")
        print(f"  Com imagem: {stats[3]} ({stats[3]/stats[0]*100:.1f}%)")
        
        # Verificar se é suficiente para ENEM
        print(f"\n🎯 Suficiência para ENEM (180 questões):")
        print(f"  Simulados completos possíveis: ~{total_geral // 180}")
        
        if total_geral >= 180:
            print("  ✅ Suficiente para simulados ENEM!")
        else:
            print(f"  ⚠️ Precisa de mais {180 - total_geral} questões")
        
    except Exception as e:
        print(f"[ERRO] Erro ao gerar estatísticas: {e}")
    
    finally:
        cursor.close()
        conn.close()

def processar_arquivo_alternativo(arquivo):
    """Tenta processar arquivo com método alternativo"""
    print(f"\n--- Processamento Alternativo: {arquivo} ---")
    
    if not os.path.exists(arquivo):
        print(f"[INFO] {arquivo} não existe")
        return []
    
    try:
        with open(arquivo, 'r', encoding='utf-8') as f:
            conteudo = f.read()
        
        questoes_encontradas = []
        
        # Método 1: Split por linhas e procurar objetos JSON
        linhas = conteudo.split('\n')
        objeto_atual = ""
        dentro_objeto = False
        
        for linha in linhas:
            linha = linha.strip()
            
            if linha.startswith('{'):
                objeto_atual = linha
                dentro_objeto = True
            elif dentro_objeto:
                objeto_atual += " " + linha
                
                if linha.endswith('}') or linha.endswith('},'):
                    # Tentar parsear objeto completo
                    try:
                        obj_limpo = objeto_atual.rstrip(',').strip()
                        questao = json.loads(obj_limpo)
                        
                        if 'question' in questao and 'correctAnswer' in questao:
                            questoes_encontradas.append(questao)
                    except:
                        pass
                    
                    objeto_atual = ""
                    dentro_objeto = False
        
        # Método 2: Regex para encontrar padrões
        import re
        
        # Procurar por "question": seguido de texto
        pattern = r'"question"\s*:\s*"([^"]*)"'
        matches = re.findall(pattern, conteudo)
        
        print(f"[INFO] Método 1 (objetos): {len(questoes_encontradas)} questões")
        print(f"[INFO] Método 2 (regex): {len(matches)} 'question' encontrados")
        
        if questoes_encontradas:
            print(f"[OK] Conseguiu extrair {len(questoes_encontradas)} questões!")
            return questoes_encontradas
        
        return []
        
    except Exception as e:
        print(f"[ERRO] Erro no processamento alternativo: {e}")
        return []

def main():
    print("INVESTIGAÇÃO E CORREÇÃO DE PROBLEMAS")
    print("="*60)
    
    # 1. Estatísticas do que já foi migrado
    estatisticas_detalhadas()
    
    # 2. Corrigir problema VARCHAR
    corrigir_problema_varchar()
    
    # 3. Investigar arquivos vazios
    investigar_arquivos_vazios()
    
    # 4. Tentar processar arquivos problemáticos
    print(f"\n{'='*60}")
    print("TENTANDO REPROCESSAR ARQUIVOS VAZIOS")
    print("="*60)
    
    arquivos_problematicos = ['MatematicaData.txt', 'EspanholData.txt', 'InglesData.txt', 'LiteraturaData.txt']
    
    for arquivo in arquivos_problematicos:
        questoes = processar_arquivo_alternativo(arquivo)
        if questoes:
            print(f"[SUCESSO] {arquivo}: {len(questoes)} questões encontradas!")
            print("  Primeiras questões:")
            for i, q in enumerate(questoes[:3]):
                print(f"    {i+1}. {q.get('question', 'Sem texto')[:50]}...")
    
    print(f"\n{'='*60}")
    print("PRÓXIMOS PASSOS")
    print("="*60)
    
    print("""
✅ SUCESSO ATUAL:
   - 1.473 questões migradas
   - 8 matérias funcionando
   - Banco PostgreSQL operacional

🔧 PRÓXIMOS PASSOS:
   1. Testar geração de simulados:
      python -c "from app.services.gerador_questoes import gerar_questoes_simulado; print('Gerador OK')"
   
   2. Criar simulado teste:
      - Agendar via interface web
      - Ou usar scripts se configurados
   
   3. Verificar resultado com explicações:
      - Interface deve mostrar explicações completas
   
   4. Corrigir arquivos problemáticos (opcional):
      - Verificar formato JSON dos arquivos vazios
      - Especialmente MatematicaData.txt (importante!)

💡 DICA:
   Mesmo com 4 arquivos problemáticos, você já tem questões
   suficientes para múltiplos simulados ENEM!
""")

if __name__ == "__main__":
    main()