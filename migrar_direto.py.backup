# migrar_direto.py
"""
Migração direta usando psycopg2, sem SQLAlchemy
"""

import psycopg2
import json
import os
import re
from pathlib import Path

def conectar_banco():
    """Conecta diretamente ao PostgreSQL"""
    try:
        conn = psycopg2.connect(
            host='localhost',
            port=5432,
            user='postgres',
            password='1469',
            database='launcher_db'
        )
        return conn
    except Exception as e:
        print(f"[ERRO] Não conseguiu conectar: {e}")
        return None

def criar_tabela(conn):
    """Cria tabela questoes_base se não existir"""
    sql_criar_tabela = """
    CREATE TABLE IF NOT EXISTS questoes_base (
        id SERIAL PRIMARY KEY,
        texto TEXT NOT NULL,
        materia VARCHAR(50) NOT NULL,
        topico VARCHAR(100) NOT NULL DEFAULT 'Não especificado',
        subtopico VARCHAR(100),
        opcao_a TEXT NOT NULL,
        opcao_b TEXT NOT NULL,
        opcao_c TEXT NOT NULL,
        opcao_d TEXT NOT NULL,
        opcao_e TEXT NOT NULL,
        resposta_correta CHAR(1) NOT NULL CHECK (resposta_correta IN ('A', 'B', 'C', 'D', 'E')),
        explicacao TEXT NOT NULL DEFAULT '',
        imagem_url VARCHAR(255),
        dificuldade FLOAT DEFAULT 0.5,
        ativa BOOLEAN DEFAULT TRUE,
        data_criacao TIMESTAMP DEFAULT NOW(),
        vezes_utilizada INTEGER DEFAULT 0,
        vezes_acertada INTEGER DEFAULT 0
    );
    
    CREATE INDEX IF NOT EXISTS idx_questoes_base_materia ON questoes_base(materia);
    CREATE INDEX IF NOT EXISTS idx_questoes_base_topico ON questoes_base(topico);
    CREATE INDEX IF NOT EXISTS idx_questoes_base_ativa ON questoes_base(ativa);
    """
    
    try:
        cursor = conn.cursor()
        cursor.execute(sql_criar_tabela)
        conn.commit()
        print("[OK] Tabela questoes_base criada/verificada")
        cursor.close()
        return True
    except Exception as e:
        print(f"[ERRO] Erro ao criar tabela: {e}")
        return False

def limpar_texto(texto):
    """Limpa texto removendo escapes desnecessários"""
    if not texto:
        return ""
    
    texto = str(texto).strip()
    if texto.startswith('"') and texto.endswith('"'):
        texto = texto[1:-1]
    
    texto = texto.replace('\\"', '"')
    texto = texto.replace('\\n', '\n')
    texto = texto.replace('\\t', '\t')
    
    return texto.strip()

def processar_arquivo_questoes(caminho_arquivo):
    """Processa arquivo de questões"""
    print(f"[INFO] Processando {caminho_arquivo}...")
    
    try:
        with open(caminho_arquivo, 'r', encoding='utf-8') as arquivo:
            conteudo = arquivo.read()
        
        # Tentar parsear como JSON
        try:
            dados = json.loads(conteudo)
            return dados if isinstance(dados, list) else [dados]
        except json.JSONDecodeError:
            # Extrair objetos JSON individuais
            padrao = r'\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}'
            matches = re.findall(padrao, conteudo, re.DOTALL)
            
            questoes = []
            for match in matches:
                try:
                    questao = json.loads(match.strip())
                    questoes.append(questao)
                except:
                    continue
            
            return questoes
    
    except Exception as e:
        print(f"[ERRO] Erro ao processar {caminho_arquivo}: {e}")
        return []

def mapear_materia(nome_arquivo):
    """Mapeia nome do arquivo para matéria"""
    mapeamento = {
        'artesdata.txt': 'Artes',
        'matematicadata.txt': 'Matemática',
        'geografiadata.txt': 'Geografia',
        'fisicadata.txt': 'Física',
        'biologiadata.txt': 'Biologia',
        'quimicadata.txt': 'Química',
        'portuguesdata.txt': 'Português',
        'literaturadata.txt': 'Literatura',
        'historiadata.txt': 'História',
        'sociologiadata.txt': 'Sociologia',
        'espanholdata.txt': 'Espanhol',
        'inglesdata.txt': 'Inglês'
    }
    
    return mapeamento.get(nome_arquivo.lower(), 'Outras')

def inserir_questao(conn, questao_data, materia):
    """Insere questão no banco"""
    # Validar campos obrigatórios
    if not questao_data.get('question'):
        return False
    
    if not questao_data.get('correctAnswer'):
        return False
    
    # Verificar duplicata
    sql_verificar = """
    SELECT id FROM questoes_base 
    WHERE texto = %s AND materia = %s
    """
    
    cursor = conn.cursor()
    cursor.execute(sql_verificar, (limpar_texto(questao_data['question']), materia))
    
    if cursor.fetchone():
        cursor.close()
        return False  # Duplicata
    
    # Inserir questão
    sql_inserir = """
    INSERT INTO questoes_base (
        texto, materia, topico, subtopico,
        opcao_a, opcao_b, opcao_c, opcao_d, opcao_e,
        resposta_correta, explicacao, imagem_url
    ) VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
    """
    
    try:
        valores = (
            limpar_texto(questao_data['question']),
            materia,
            limpar_texto(questao_data.get('topico', 'Não especificado')),
            limpar_texto(questao_data.get('subtopico', '')),
            limpar_texto(questao_data.get('answerA', '')),
            limpar_texto(questao_data.get('answerB', '')),
            limpar_texto(questao_data.get('answerC', '')),
            limpar_texto(questao_data.get('answerD', '')),
            limpar_texto(questao_data.get('answerE', '')),
            questao_data['correctAnswer'].upper(),
            limpar_texto(questao_data.get('correctAnswermessage', 
                        questao_data.get('correctAnswerMessage', ''))),
            limpar_texto(questao_data.get('image', ''))
        )
        
        cursor.execute(sql_inserir, valores)
        conn.commit()
        cursor.close()
        return True
        
    except Exception as e:
        print(f"[ERRO] Erro ao inserir questão: {e}")
        conn.rollback()
        cursor.close()
        return False

def migrar_todas_questoes():
    """Migra todas as questões"""
    # Conectar ao banco
    conn = conectar_banco()
    if not conn:
        return False
    
    # Criar tabela
    if not criar_tabela(conn):
        conn.close()
        return False
    
    # Encontrar arquivos
    arquivos_dados = list(Path('.').glob('*Data.txt'))
    
    if not arquivos_dados:
        print("[ERRO] Nenhum arquivo *Data.txt encontrado!")
        conn.close()
        return False
    
    print(f"[INFO] Encontrados {len(arquivos_dados)} arquivos")
    
    total_inseridas = 0
    total_processadas = 0
    
    for arquivo in arquivos_dados:
        nome_arquivo = arquivo.name
        materia = mapear_materia(nome_arquivo)
        
        print(f"\n=== {nome_arquivo} ({materia}) ===")
        
        questoes = processar_arquivo_questoes(arquivo)
        
        if not questoes:
            print("[INFO] Nenhuma questão encontrada")
            continue
        
        inseridas = 0
        
        for questao in questoes:
            total_processadas += 1
            
            if inserir_questao(conn, questao, materia):
                inseridas += 1
                total_inseridas += 1
        
        print(f"[OK] {inseridas} questões inseridas de {len(questoes)} processadas")
    
    # Estatísticas finais
    cursor = conn.cursor()
    cursor.execute("SELECT COUNT(*) FROM questoes_base")
    total_banco = cursor.fetchone()[0]
    cursor.close()
    
    print(f"\n=== RESUMO ===")
    print(f"Questões processadas: {total_processadas}")
    print(f"Questões inseridas: {total_inseridas}")
    print(f"Total no banco: {total_banco}")
    
    conn.close()
    return True

def main():
    print("MIGRACAO DIRETA DE QUESTOES (sem SQLAlchemy)")
    print("="*50)
    
    if migrar_todas_questoes():
        print("\n[SUCESSO] Migração concluída!")
        print("\nVerificar resultado:")
        print("  python -c \"")
        print("import psycopg2")
        print("conn = psycopg2.connect(host='localhost', user='postgres', password='1469', database='launcher_db')")
        print("cursor = conn.cursor()")
        print("cursor.execute('SELECT materia, COUNT(*) FROM questoes_base GROUP BY materia')")
        print("for row in cursor.fetchall(): print(f'{row[0]}: {row[1]} questões')")
        print("conn.close()\"")
    else:
        print("\n[ERRO] Migração falhou!")

if __name__ == "__main__":
    main()