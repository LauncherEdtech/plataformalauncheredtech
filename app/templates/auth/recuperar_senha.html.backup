<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Recuperar Senha — Plataforma Launcher</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <style>
    /* Usar os mesmos estilos do login.html */
    :root{
      --bg: #000000;
      --bg-gradient: radial-gradient(ellipse at top, #111111 0%, #000000 100%);
      --surface: #111111;
      --surface-light: #1a1a1a;
      --primary: #3b82f6;
      --accent: #00d9ff;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --text: #ffffff;
      --text-muted: #a1a1aa;
      --text-secondary: #9fb1d1;
      --border: #262626;
      --focus: rgba(59, 130, 246, 0.3);
      --radius: 16px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-gradient);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .container {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      max-width: 400px;
      width: 100%;
      box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.5);
    }

    .header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .logo {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white;
      font-weight: 800;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .label {
      display: block;
      color: var(--text-secondary);
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    .input {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface-light);
      color: var(--text);
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 4px var(--focus);
    }

    .btn {
      width: 100%;
      padding: 12px 20px;
      border: none;
      border-radius: var(--radius);
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-bottom: 1rem;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(59, 130, 246, 0.4);
    }

    .btn-secondary {
      background: transparent;
      border: 2px solid var(--border);
      color: var(--text-muted);
    }

    .btn-secondary:hover {
      border-color: var(--primary);
      color: var(--text);
      transform: none;
      box-shadow: none;
    }

    .alert {
      padding: 12px 16px;
      border-radius: var(--radius);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.9rem;
    }

    .alert-info {
      background: rgba(0, 217, 255, 0.1);
      border: 1px solid rgba(0, 217, 255, 0.3);
      color: #a5f3fc;
    }

    .alert-warning {
      background: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.3);
      color: #fde68a;
    }

    .alert-success {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
      color: #d1fae5;
    }

    .alert-danger {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #ffd5d5;
    }

    .info-box {
      background: rgba(59, 130, 246, 0.05);
      border: 1px solid rgba(59, 130, 246, 0.2);
      border-radius: var(--radius);
      padding: 1rem;
      margin-bottom: 1.5rem;
      font-size: 0.85rem;
      line-height: 1.5;
    }

    .contact-info {
      text-align: center;
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .contact-info strong {
      color: var(--accent);
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">L</div>
      <h1>Recuperar Senha</h1>
      <p class="subtitle">Digite seu email ou CPF para continuar</p>
    </div>

    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        {% for category, message in messages %}
          <div class="alert alert-{{ category }}">
            {% if category == 'danger' %}
              <i class="bi bi-exclamation-triangle-fill"></i>
            {% elif category == 'warning' %}
              <i class="bi bi-exclamation-triangle"></i>
            {% elif category == 'success' %}
              <i class="bi bi-check-circle-fill"></i>
            {% else %}
              <i class="bi bi-info-circle"></i>
            {% endif %}
            <span>{{ message }}</span>
          </div>
        {% endfor %}
      {% endif %}
    {% endwith %}

    <div class="info-box">
      <strong>Primeira vez na plataforma?</strong><br>
      Se você acabou de comprar, use seu CPF como senha inicial. Você será solicitado a alterar no primeiro login.
    </div>

    <form method="POST">
      <div class="form-group">
        <label class="label" for="email">Email ou CPF</label>
        <input 
          class="input" 
          type="text" 
          id="email" 
          name="email" 
          placeholder="seu@email.com ou 000.000.000-00"
          required
        >
      </div>

      <button type="submit" class="btn">
        <i class="bi bi-send"></i>
        Enviar Instruções
      </button>
      
      <a href="{{ url_for('auth.login') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Voltar ao Login
      </a>
    </form>

    <div class="contact-info">
      <p><strong>Precisa de ajuda?</strong></p>
      <p>WhatsApp: <strong>(62) 99559-4055</strong></p>
      <p>Email: <strong>suporte@plataformalauncher.com.br</strong></p>
    </div>
  </div>
</body>
</html>
