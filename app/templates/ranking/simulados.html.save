<!-- templates/ranking/simulados.html -->
{% extends "layout.html" %}

{% block title %}Ranking Simulados - Plataforma Launcher{% endblock %}

{% block styles %}
<style>
    :root {
        --primary-color: #001233;
        --secondary-color: #003d82;
        --tertiary-color: #004080;
        --accent-gold: #FFD700;
        --accent-silver: #C0C0C0;
        --accent-bronze: #CD7F32;
        --accent-blue: #007bff;
        --accent-green: #28a745;
        --text-color: #ffffff;
        --card-bg: rgba(30, 30, 30, 0.95);
        --gradient-primary: linear-gradient(135deg, #001233, #003d82);
        --gradient-secondary: linear-gradient(135deg, #003d82, #004080);
        --gradient-simulados: linear-gradient(135deg, #007bff, #0056b3);
        --gradient-gold: linear-gradient(135deg, #FFD700, #FFA500);
        --gradient-silver: linear-gradient(135deg, #C0C0C0, #A0A0A0);
        --gradient-bronze: linear-gradient(135deg, #CD7F32, #8B4513);
        --gradient-card: linear-gradient(145deg, rgba(30, 30, 30, 0.95), rgba(20, 20, 20, 0.9));
        --gradient-hero: linear-gradient(135deg, rgba(0, 18, 51, 0.4), rgba(0, 123, 255, 0.2));
        --glow-gold: 0 0 30px rgba(255, 215, 0, 0.5);
        --glow-blue: 0 0 30px rgba(0, 123, 255, 0.4);
        --glow-green: 0 0 30px rgba(40, 167, 69, 0.4);
    }

    body {
        background: linear-gradient(to bottom, #001233 0%, #000000 25%, #000 40%, #000 100%);
        color: white;
        overflow-x: hidden;
    }

    .ranking-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
        min-height: 100vh;
    }

    /* Hero Section */
    .hero-section {
        text-align: center;
        padding: 3rem 0;
        margin-bottom: 3rem;
        background: var(--gradient-hero);
        border-radius: 25px;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 123, 255, 0.3);
        position: relative;
        overflow: hidden;
        animation: fadeInDown 0.8s ease-out;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-simulados);
        opacity: 0.9;
    }

    .hero-section::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(0, 123, 255, 0.1) 0%, transparent 70%);
        animation: rotate 20s linear infinite;
        z-index: -1;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 1rem;
        background: var(--gradient-simulados);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
    }

    .hero-subtitle {
        font-size: 1.3rem;
        opacity: 0.9;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto 2rem auto;
        line-height: 1.6;
    }

    .journal-icon {
        color: var(--accent-blue);
        font-size: 1.5rem;
        margin-right: 0.75rem;
        animation: bounce 2s infinite;
    }

    /* Performance Highlight Banner */
    .performance-highlight {
        background: var(--gradient-card);
        border: 2px solid rgba(0, 123, 255, 0.4);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 3rem;
        text-align: center;
        backdrop-filter: blur(20px);
        box-shadow: 
            var(--glow-blue),
            0 15px 35px rgba(0, 0, 0, 0.3);
        position: relative;
        overflow: hidden;
        animation: slideInUp 0.8s ease-out 0.2s both;
    }

    .performance-highlight::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gradient-simulados);
        opacity: 0.9;
    }

    .performance-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--text-color);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .performance-description {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.8);
        margin: 0;
        line-height: 1.5;
    }

    .graph-icon {
        color: var(--accent-blue);
        font-size: 1.3rem;
        animation: pulse 2s infinite;
    }

    /* Navigation Tabs */
    .tab-navigation {
        background: var(--gradient-card);
        border-radius: 20px;
        padding: 1rem;
        margin-bottom: 3rem;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 123, 255, 0.3);
        box-shadow: 
            0 15px 35px rgba(0, 0, 0, 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        animation: slideInUp 0.8s ease-out 0.4s both;
    }

    .nav-tabs-custom {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .tab-btn {
        flex: 1;
        min-width: 200px;
        padding: 1.25rem 2rem;
        border: none;
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.8);
        border-radius: 15px;
        text-decoration: none;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-weight: 600;
        position: relative;
        overflow: hidden;
        border: 2px solid transparent;
        backdrop-filter: blur(10px);
    }

    .tab-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.6s;
    }

    .tab-btn:hover::before {
        left: 100%;
    }

    .tab-btn:hover {
        background: rgba(0, 123, 255, 0.3);
        color: white;
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 10px 25px rgba(0, 123, 255, 0.4);
        border-color: rgba(0, 123, 255, 0.5);
    }

    .tab-btn.active {
        background: var(--gradient-simulados);
        color: white;
        box-shadow: var(--glow-blue);
        border-color: var(--accent-blue);
        transform: translateY(-2px);
    }

    .tab-btn.active::before {
        display: none;
    }

    /* User Stats */
    .user-stats {
        background: var(--gradient-card);
        border-radius: 25px;
        padding: 2.5rem 2rem;
        margin-bottom: 3rem;
        border: 1px solid rgba(0, 123, 255, 0.3);
        backdrop-filter: blur(20px);
        box-shadow: 
            0 20px 40px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
        animation: slideInUp 0.8s ease-out 0.6s both;
    }

    .user-stats::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gradient-simulados);
        opacity: 0.9;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
    }

    .stat-item {
        text-align: center;
        padding: 2rem 1rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .stat-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gradient-simulados);
        transform: scaleX(0);
        transition: transform 0.3s ease;
    }

    .stat-item:hover {
        background: rgba(0, 123, 255, 0.2);
        transform: translateY(-8px) scale(1.02);
        border-color: var(--accent-blue);
        box-shadow: 0 15px 35px rgba(0, 123, 255, 0.3);
    }

    .stat-item:hover::before {
        transform: scaleX(1);
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--accent-blue);
        display: block;
        margin-bottom: 0.75rem;
        text-shadow: 0 2px 10px rgba(0, 123, 255, 0.4);
        position: relative;
    }

    .stat-label {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
        margin-top: 0.5rem;
    }

    .stat-icon {
        font-size: 1.5rem;
        color: var(--accent-blue);
        margin-bottom: 1rem;
        display: block;
    }

    /* Performance Badge */
    .performance-badge {
        margin-top: 1.5rem;
        text-align: center;
    }

    .nota-badge {
        border-radius: 20px;
        padding: 0.5rem 1.2rem;
        font-weight: 700;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .nota-badge:hover {
        transform: scale(1.05);
    }

    .nota-excelente { 
        background: linear-gradient(45deg, #28a745, #20c997); 
        color: white; 
        box-shadow: var(--glow-green);
        border-color: rgba(40, 167, 69, 0.5);
    }
    .nota-boa { 
        background: var(--gradient-simulados); 
        color: white; 
        box-shadow: var(--glow-blue);
        border-color: rgba(0, 123, 255, 0.5);
    }
    .nota-media { 
        background: var(--gradient-gold); 
        color: #000; 
        box-shadow: var(--glow-gold);
        border-color: rgba(255, 215, 0, 0.5);
    }
    .nota-baixa { 
        background: linear-gradient(45deg, #dc3545, #c82333); 
        color: white; 
        box-shadow: 0 0 20px rgba(220, 53, 69, 0.4);
        border-color: rgba(220, 53, 69, 0.5);
    }

    /* Podium Section */
    .podium-section {
        background: var(--gradient-card);
        border-radius: 25px;
        padding: 3rem 2rem;
        margin-bottom: 3rem;
        border: 1px solid rgba(255, 215, 0, 0.3);
        backdrop-filter: blur(20px);
        box-shadow: 
            0 25px 50px rgba(0, 0, 0, 0.4),
            var(--glow-gold);
        position: relative;
        overflow: hidden;
        animation: slideInUp 0.8s ease-out 0.8s both;
    }

    .podium-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-gold);
        opacity: 0.9;
    }

    .podium-title {
        text-align: center;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 3rem;
        background: var(--gradient-gold);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
    }

    .crown-icon {
        color: var(--accent-gold);
        font-size: 1.8rem;
        margin-left: 0.5rem;
        animation: pulse 2s infinite;
        filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.7));
    }

    .podium-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr 1fr;
        gap: 2rem;
        align-items: end;
    }

    .podium-position {
        text-align: center;
        padding: 2rem 1rem;
        background: rgba(0, 0, 0, 0.4);
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .podium-position::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 100%;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: -1;
    }

    .podium-position.first {
        height: 320px;
        border: 3px solid var(--accent-gold);
        box-shadow: var(--glow-gold);
    }

    .podium-position.first::before {
        background: var(--gradient-gold);
    }

    .podium-position.second {
        height: 270px;
        border: 3px solid var(--accent-silver);
        box-shadow: 0 0 20px rgba(192, 192, 192, 0.4);
    }

    .podium-position.second::before {
        background: var(--gradient-silver);
    }

    .podium-position.third {
        height: 220px;
        border: 3px solid var(--accent-bronze);
        box-shadow: 0 0 20px rgba(205, 127, 50, 0.4);
    }

    .podium-position.third::before {
        background: var(--gradient-bronze);
    }

    .podium-position:hover::before {
        opacity: 0.1;
    }

    .podium-position:hover {
        transform: translateY(-10px) scale(1.05);
    }
   .rank-badge {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.8rem;
        margin: 0 auto 1.5rem auto;
        position: relative;
        z-index: 2;
        transition: all 0.3s ease;
    }

    .rank-badge.rank-1 {
        background: var(--gradient-gold);
        color: #000;
        box-shadow: var(--glow-gold);
        animation: shine 3s infinite;
    }

    .rank-badge.rank-2 {
        background: var(--gradient-silver);
        color: #000;
        box-shadow: 0 0 20px rgba(192, 192, 192, 0.5);
    }

    .rank-badge.rank-3 {
        background: var(--gradient-bronze);
        color: #fff;
        box-shadow: 0 0 20px rgba(205, 127, 50, 0.5);
    }

    .podium-position:hover .rank-badge {
        transform: scale(1.1) rotate(10deg);
    }

    .podium-name {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-color);
    }

    .podium-score {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--accent-blue);
        text-shadow: 0 2px 10px rgba(0, 123, 255, 0.4);
        margin-bottom: 0.5rem;
    }

    .podium-simulados {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 1rem;
    }

    .podium-badge {
        margin-top: 1rem;
    }

    /* Ranking Cards */
    .ranking-card {
        background: var(--gradient-card);
        border: 1px solid rgba(0, 123, 255, 0.3);
        border-radius: 25px;
        backdrop-filter: blur(20px);
        box-shadow: 
            0 20px 40px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        animation: slideInUp 0.8s ease-out 1s both;
    }

    .ranking-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gradient-simulados);
        opacity: 0.9;
    }

    .ranking-card:hover {
        transform: translateY(-5px);
        box-shadow: 
            0 30px 60px rgba(0, 0, 0, 0.5),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .ranking-header {
        padding: 2rem 2.5rem 1rem 2.5rem;
        border-bottom: 1px solid rgba(0, 123, 255, 0.3);
    }

    .ranking-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-color);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 0;
    }

    .ranking-list {
        padding: 1.5rem;
        max-height: 600px;
        overflow-y: auto;
    }

    .ranking-list::-webkit-scrollbar {
        width: 8px;
    }

    .ranking-list::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.3);
        border-radius: 4px;
    }

    .ranking-list::-webkit-scrollbar-thumb {
        background: var(--gradient-simulados);
        border-radius: 4px;
    }

    .ranking-item {
        background: rgba(0, 0, 0, 0.3);
        border-radius: 15px;
        padding: 1.5rem 2rem;
        margin-bottom: 1rem;
        border: 2px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        gap: 1.5rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .ranking-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(0, 123, 255, 0.3), transparent);
        transition: left 0.6s;
    }

    .ranking-item:hover::before {
        left: 100%;
    }

    .ranking-item:hover {
        background: rgba(0, 123, 255, 0.2);
        transform: translateX(10px) scale(1.02);
        border-color: var(--accent-blue);
        box-shadow: 0 10px 25px rgba(0, 123, 255, 0.3);
    }

    .ranking-item:last-child {
        margin-bottom: 0;
    }

    .ranking-item.user-highlight {
        background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(255, 215, 0, 0.1));
        border: 2px solid rgba(255, 215, 0, 0.5);
        box-shadow: var(--glow-gold);
        animation: glow 2s infinite alternate;
    }

    .ranking-item.user-highlight::before {
        background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.3), transparent);
    }

    .rank-badge-small {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        flex-shrink: 0;
        transition: all 0.3s ease;
    }

    .rank-other {
        background: linear-gradient(45deg, #495057, #6c757d);
        color: #fff;
    }

    .ranking-item:hover .rank-badge-small {
        transform: scale(1.1) rotate(5deg);
    }

    .user-info {
        flex-grow: 1;
    }

    .user-name {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: var(--text-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .user-username {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 0.75rem;
    }

    .simulado-stats {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
    }

    .mini-stat {
        background: rgba(0, 123, 255, 0.2);
        border-radius: 15px;
        padding: 0.3rem 0.8rem;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(0, 123, 255, 0.3);
        transition: all 0.3s ease;
    }

    .mini-stat:hover {
        background: rgba(0, 123, 255, 0.3);
        transform: scale(1.05);
    }

    .progress-container {
        margin-top: 0.75rem;
    }

    .progress {
        height: 6px;
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .progress-bar-nota {
        background: var(--gradient-simulados);
        border-radius: 10px;
        height: 100%;
        transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .progress-bar-nota::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
        animation: progressShine 2s infinite;
    }

    .user-score {
        text-align: right;
        flex-shrink: 0;
    }

    .score-value {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--accent-blue);
        text-shadow: 0 2px 10px rgba(0, 123, 255, 0.3);
    }

    .score-label {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.6);
        margin-top: 0.25rem;
    }

    .badge-you {
        background: var(--gradient-gold);
        color: #000;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.8rem;
        margin-left: 0.5rem;
    }

    /* Empty States */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(255, 255, 255, 0.6);
    }

    .empty-state i {
        font-size: 4rem;
        margin-bottom: 2rem;
        opacity: 0.3;
        animation: pulse 2s infinite;
    }

    .empty-state h4 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--text-color);
    }

    .no-score-state {
        background: rgba(0, 123, 255, 0.1);
        border: 2px dashed rgba(0, 123, 255, 0.3);
        border-radius: 20px;
        padding: 3rem 2rem;
        text-align: center;
        margin-top: 2rem;
    }

    .start-btn {
        background: var(--gradient-simulados);
        border: none;
        color: white;
        padding: 1rem 2rem;
        border-radius: 15px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        margin-top: 1.5rem;
    }

    .start-btn:hover {
        background: linear-gradient(135deg, #0056b3, #004080);
        transform: translateY(-3px) scale(1.05);
        box-shadow: var(--glow-blue);
        color: white;
    }

    /* Tips Section */
    .tips-section {
        background: var(--gradient-card);
        border-radius: 25px;
        padding: 2.5rem;
        margin-top: 3rem;
        border: 1px solid rgba(0, 123, 255, 0.3);
        backdrop-filter: blur(20px);
        box-shadow: 
            0 15px 35px rgba(0, 0, 0, 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        animation: slideInUp 0.8s ease-out 1.2s both;
    }

    .tips-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 2rem;
        color: var(--text-color);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .tips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .tip-item {
        padding: 1.5rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 15px;
        transition: all 0.3s ease;
        border: 2px solid rgba(255, 255, 255, 0.1);
    }

    .tip-item:hover {
        background: rgba(0, 123, 255, 0.2);
        transform: translateY(-5px);
        border-color: var(--accent-blue);
    }

    .tip-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .tip-icon {
        font-size: 1.3rem;
        padding: 0.5rem;
        border-radius: 8px;
    }

    .tip-icon.repeat { background: rgba(0, 123, 255, 0.2); color: #007bff; }
    .tip-icon.clock { background: rgba(40, 167, 69, 0.2); color: #28a745; }
    .tip-icon.graph { background: rgba(23, 162, 184, 0.2); color: #17a2b8; }
    .tip-icon.target { background: rgba(255, 193, 7, 0.2); color: #ffc107; }

    .tip-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-color);
        margin: 0;
    }

    .tip-description {
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.5;
        margin: 0;
    }

    /* Animations */
    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(-10px);
        }
        60% {
            transform: translateY(-5px);
        }
    }

    @keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.8;
            transform: scale(1.05);
        }
    }

    @keyframes rotate {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }

    @keyframes shine {
        0%, 100% {
            filter: brightness(1) saturate(1);
        }
        50% {
            filter: brightness(1.2) saturate(1.3);
        }
    }

    @keyframes glow {
        0% {
            box-shadow: var(--glow-gold);
        }
        100% {
            box-shadow: 0 0 40px rgba(255, 215, 0, 0.7);
        }
    }

    @keyframes progressShine {
        0% {
            left: -100%;
        }
        100% {
            left: 100%;
        }
    }


    /* Loading Animation */
    .loading-skeleton {
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.1) 25%, rgba(255, 255, 255, 0.2) 50%, rgba(255, 255, 255, 0.1) 75%);
        background-size: 200% 100%;
        animation: loading 1.5s infinite;
    }

    @keyframes loading {
        0% {
            background-position: 200% 0;
        }
        100% {
            background-position: -200% 0;
        }
    }

    /* Responsiveness */
    @media (max-width: 1200px) {
        .podium-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        
        .podium-position {
            height: auto !important;
        }
    }

    @media (max-width: 768px) {
        .ranking-container {
            padding: 0 0.5rem;
        }
        
        .hero-title {
            font-size: 2.2rem;
        }
        
        .hero-subtitle {
            font-size: 1.1rem;
        }
        
        .nav-tabs-custom {
            flex-direction: column;
        }
        
        .tab-btn {
            min-width: auto;
        }
        
        .stats-grid {
            grid-template-columns: repeat(auto-fit, minWidth(200px, 1fr));
            gap: 1rem;
        }
        
        .stat-item {
            padding: 1.5rem 1rem;
        }
        
        .stat-value {
            font-size: 2rem;
        }
        
        .podium-section, .performance-highlight, .tips-section {
            padding: 2rem 1rem;
        }
        
        .ranking-header {
            padding: 1.5rem;
        }
        
        .ranking-item {
            padding: 1rem 1.5rem;
        }
        
        .user-name {
            font-size: 1rem;
        }
        
        .score-value {
            font-size: 1.2rem;
        }
        
        .tips-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
        
        .tip-item {
            padding: 1rem;
        }
        
        .simulado-stats {
            flex-direction: column;
            gap: 0.5rem;
        }
    }

    @media (max-width: 480px) {
        .hero-title {
            font-size: 1.8rem;
        }
        
        .stats-grid {
            grid-template-columns: 1fr;
        }
        
        .ranking-item {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }
        
        .user-score {
            text-align: center;
        }
        
        .rank-badge-small {
            margin-bottom: 1rem;
        }
        
        .user-name {
            justify-content: center;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="ranking-container">
    <!-- Hero Section -->
    <section class="hero-section">
        <h1 class="hero-title">
            <i class="bi bi-journal-check journal-icon"></i>
            Ranking de Simulados
        </h1>
        <p class="hero-subtitle">
            Os melhores desempenhos em simulados de {{ mes_atual }}! 🎯<br>
            Baseado na média das notas TRI. Mostre sua excelência acadêmica!
        </p>
    </section>

    <!-- Performance Highlight Banner -->
    <section class="performance-highlight">
        <h2 class="performance-title">
            <i class="bi bi-graph-up graph-icon"></i>
            Ranking de Performance em {{ mes_atual.split()[0] }}
        </h2>
        <p class="performance-description">
            Baseado na média das notas TRI dos simulados realizados no mês. Mínimo: 1 simulado concluído.
            Prove sua consistência e conhecimento!
        </p>
    </section>

    <!-- Navigation Tabs -->
    <nav class="tab-navigation">
        <div class="nav-tabs-custom">
            <a href="{{ url_for('ranking.index') }}" class="tab-btn">
                <i class="bi bi-trophy me-2"></i>
                XP Geral
            </a>
            <a href="{{ url_for('ranking.mensal') }}" class="tab-btn">
                <i class="bi bi-calendar-month me-2"></i>
                Mensal
            </a>
            <a href="{{ url_for('ranking.tempo_estudo') }}" class="tab-btn">
                <i class="bi bi-clock me-2"></i>
                Tempo de Estudo
            </a>
            <a href="{{ url_for('ranking.simulados') }}" class="tab-btn active">
                <i class="bi bi-journal-check me-2"></i>
                Simulados
            </a>
        </div>
    </nav>

    <!-- User Stats -->
    <section class="user-stats">
        <div class="stats-grid">
            <div class="stat-item" onclick="showStatsDetail('media')">
                <i class="stat-icon bi bi-graph-up-arrow"></i>
                <div class="stat-value" data-count="{{ stats_usuario.media_notas|round if stats_usuario.media_notas else 0 }}">
                    {% if stats_usuario.media_notas %}
                        {{ "%.0f"|format(stats_usuario.media_notas) }}
                    {% else %}
                        --
                    {% endif %}
                </div>
                <div class="stat-label">Sua Média TRI</div>
            </div>
            <div class="stat-item" onclick="showStatsDetail('position')">
                <i class="stat-icon bi bi-award-fill"></i>
                <div class="stat-value">
                    {% if posicao_usuario %}#{{ posicao_usuario }}{% else %}--{% endif %}
                </div>
                <div class="stat-label">Sua Posição</div>
            </div>
            <div class="stat-item" onclick="showStatsDetail('simulados')">
                <i class="stat-icon bi bi-journal-check"></i>
                <div class="stat-value" data-count="{{ stats_usuario.total_simulados or 0 }}">{{ stats_usuario.total_simulados or 0 }}</div>
                <div class="stat-label">Simulados Feitos</div>
            </div>
            <div class="stat-item" onclick="showStatsDetail('melhor')">
                <i class="stat-icon bi bi-star-fill"></i>
                <div class="stat-value" data-count="{{ stats_usuario.melhor_nota|round if stats_usuario.melhor_nota else 0 }}">
                    {% if stats_usuario.melhor_nota %}
                        {{ "%.0f"|format(stats_usuario.melhor_nota) }}
                    {% else %}
                        --
                    {% endif %}
                </div>
                <div class="stat-label">Melhor Nota</div>
            </div>
        </div>
        
        <!-- Performance Badge -->
        {% if stats_usuario.media_notas %}
        <div class="performance-badge">
            {% if stats_usuario.media_notas >= 700 %}
                <span class="nota-badge nota-excelente">
                    <i class="bi bi-star-fill"></i>
                    Performance Excelente
                </span>
            {% elif stats_usuario.media_notas >= 600 %}
                <span class="nota-badge nota-boa">
                    <i class="bi bi-trophy"></i>
                    Boa Performance
                </span>
            {% elif stats_usuario.media_notas >= 500 %}
                <span class="nota-badge nota-media">
                    <i class="bi bi-arrow-up"></i>
                    Performance Média
                </span>
            {% else %}
                <span class="nota-badge nota-baixa">
                    <i class="bi bi-arrow-up"></i>
                    Foco na Melhoria
                </span>
            {% endif %}
        </div>
        {% endif %}
    </section>

    <!-- Podium Section -->
    {% if ranking_simulados|length >= 3 %}
    <section class="podium-section">
        <h2 class="podium-title">
            <i class="bi bi-award crown-icon"></i>
            Top Performers de {{ mes_atual.split()[0] }}
        </h2>
        
        <div class="podium-grid">
            <!-- 2º Lugar -->
            <div class="podium-position second" onclick="showUserProfile({{ ranking_simulados[1].id }})">
                <div class="rank-badge rank-2">2º</div>
                <h3 class="podium-name">{{ ranking_simulados[1].nome_completo or ranking_simulados[1].username }}</h3>
                <div class="podium-score">{{ "%.0f"|format(ranking_simulados[1].media_notas) }} pts</div>
                <div class="podium-simulados">{{ ranking_simulados[1].total_simulados }} simulado(s)</div>
            </div>
            
            <!-- 1º Lugar -->
            <div class="podium-position first" onclick="showUserProfile({{ ranking_simulados[0].id }})">
                <div class="rank-badge rank-1">1º</div>
                <h3 class="podium-name">
                    {{ ranking_simulados[0].nome_completo or ranking_simulados[0].username }}
                    <i class="bi bi-crown crown-icon"></i>
                </h3>
                <div class="podium-score">{{ "%.0f"|format(ranking_simulados[0].media_notas) }} pts</div>
                <div class="podium-simulados">{{ ranking_simulados[0].total_simulados }} simulado(s)</div>
                <div class="podium-badge">
                    <span class="nota-badge nota-excelente">
                        <i class="bi bi-lightning"></i>
                        Top Performer
                    </span>
                </div>
            </div>


