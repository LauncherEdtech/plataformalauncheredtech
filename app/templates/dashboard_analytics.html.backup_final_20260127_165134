async function mostrarUsuariosSegmento(segmento) {
    const nomeSegmento = {
        'super_engajados': 'Super Engajados (>10h)',
        'engajados': 'Engajados (5-10h)',
        'moderados': 'Moderados (1-5h)',
        'baixo_engajamento': 'Baixo Engajamento (<1h)',
        'inativos': 'Inativos (0h)'
    }[segmento];
    
    abrirModal(`Carregando ${nomeSegmento}...`);
    
    try {
        const response = await fetch(`/dashboard-analytics/api/analise-segmentacao/${segmento}`);
        const data = await response.json();
        
        if (data.erro) {
            throw new Error(data.erro);
        }
        
        const usuariosHTML = data.usuarios.map(u => `
            <tr onclick="abrirDetalhesUsuario(${u.id})">
                <td><strong>${u.nome_completo}</strong></td>
                <td>${u.telefone}</td>
                <td>
                    <span class="badge badge-${u.plano === 'free' ? 'secondary' : 'success'}">
                        ${u.plano.toUpperCase()}
                    </span>
                </td>
                <td><strong>${u.tempo_total_horas}h</strong> (${u.tempo_total_minutos}min)</td>
                <td>${u.ultimo_acesso}</td>
            </tr>
        `).join('');
        
        const conteudo = `
            <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
                ${nomeSegmento}
            </h2>
            
            <div class="detail-grid" style="margin-bottom: 2rem;">
                <div class="detail-item">
                    <label>Total de Usuários</label>
                    <div class="value">${data.total}</div>
                </div>
                <div class="detail-item">
                    <label>Segmento</label>
                    <div class="value" style="font-size: 1rem;">${nomeSegmento}</div>
                </div>
            </div>
            
            <div style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>NOME COMPLETO</th>
                            <th>TELEFONE</th>
                            <th>Plano</th>
                            <th>Tempo Total</th>
                            <th>Último Acesso</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${usuariosHTML || '<tr><td colspan="5" style="text-align: center;">Nenhum usuário neste segmento</td></tr>'}
                    </tbody>
                </table>
            </div>
            
            <p style="margin-top: 1rem; text-align: center; color: var(--medium-gray); font-size: 0.875rem;">
                💡 Clique em qualquer usuário para ver detalhes completos
            </p>
        `;
        
        renderizarConteudoModal(conteudo);
        
    } catch (error) {
        mostrarErroModal('Erro ao carregar segmento: ' + error.message);
    }
}





