{% extends "layout.html" %}

{% block title %}Simulado Personalizado - Plataforma Launcher{% endblock %}

{% block content %}
<style>
    :root {
        --primary-blue: #00205B;
        --secondary-blue: #001233;
        --accent-cyan: #00b4d8;
        --accent-purple: #6c13d3;
        --success-color: #28a745;
        --text-color: #ffffff;
        --card-bg: rgba(13, 17, 23, 0.95);
        --warning-color: #ffc107;
        --danger-color: #dc3545;
        --gradient-primary: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
        --gradient-accent: linear-gradient(135deg, var(--accent-cyan), #0077b6);
        --gradient-purple: linear-gradient(135deg, var(--accent-purple), #7e25e3);
        --gradient-success: linear-gradient(135deg, var(--success-color), #20c997);
        --gradient-card: linear-gradient(145deg, rgba(13, 17, 23, 0.95), rgba(8, 12, 18, 0.9));
        --gradient-hero: linear-gradient(135deg, rgba(0, 32, 91, 0.2), rgba(0, 18, 51, 0.1));
    }

    body {
        background: linear-gradient(to bottom, #00205B 0%, #001233 25%, #000 40%, #000 100%);
        color: white;
        overflow-x: hidden;
    }
    
    .agendar-simulado {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        min-height: 100vh;
    }
    
    /* Header Section */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        padding: 2rem 0;
        border-bottom: 2px solid rgba(0, 180, 216, 0.3);
        animation: slideInDown 0.8s ease-out;
        position: relative;
    }
    
    .page-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 3px;
        background: var(--gradient-accent);
        border-radius: 2px;
    }
    
    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        background: var(--gradient-accent);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .page-title i {
        color: var(--accent-cyan);
        animation: pulse 2s infinite;
    }
    
    .back-btn {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
        border: 2px solid rgba(255, 255, 255, 0.2);
        color: var(--text-color);
        padding: 1rem 2rem;
        border-radius: 15px;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 600;
        position: relative;
        overflow: hidden;
    }
    
    .back-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.6s;
    }
    
    .back-btn:hover::before {
        left: 100%;
    }
    
    .back-btn:hover {
        background: var(--gradient-accent);
        border-color: var(--accent-cyan);
        color: white;
        transform: translateX(-8px) scale(1.02);
        box-shadow: 0 12px 30px rgba(0, 180, 216, 0.4);
    }
    
    .page-subtitle {
        font-size: 1.3rem;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 3rem;
        text-align: center;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }
    
    /* Progress Indicator */
    .progress-indicator {
        display: flex;
        justify-content: center;
        margin-bottom: 3rem;
        gap: 1rem;
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }
    
    .progress-step {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        border: 3px solid rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition: all 0.4s ease;
        position: relative;
    }
    
    .progress-step::after {
        content: '';
        position: absolute;
        bottom: -30px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.8rem;
        white-space: nowrap;
        color: rgba(255, 255, 255, 0.7);
    }
    
    .progress-step:nth-child(1)::after { content: 'Áreas'; }
    .progress-step:nth-child(2)::after { content: 'Questões'; }
    .progress-step:nth-child(3)::after { content: 'Duração'; }
    
    .progress-step.active {
        background: var(--gradient-accent);
        border-color: var(--accent-cyan);
        color: white;
        transform: scale(1.1);
        box-shadow: 0 0 20px rgba(0, 180, 216, 0.5);
    }
    
    .progress-step.completed {
        background: var(--gradient-accent);
        border-color: var(--accent-cyan);
        color: white;
    }
    
    /* Form Container */
    .form-container {
        background: var(--gradient-card);
        border: 1px solid rgba(0, 180, 216, 0.3);
        border-radius: 25px;
        backdrop-filter: blur(20px);
        box-shadow: 
            0 20px 40px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        overflow: hidden;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out 0.6s both;
        position: relative;
    }

    .form-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-accent);
        opacity: 0.9;
    }
    
    .form-body {
        padding: 3rem;
    }
    
    /* Form Sections */
    .form-section {
        margin-bottom: 4rem;
        position: relative;
    }
    
    .section-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text-color);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .section-title i {
        color: var(--accent-cyan);
        font-size: 1.4rem;
    }
    
    .section-subtitle {
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 2rem;
        font-size: 1.05rem;
    }
    
    /* Areas Selection */
    .areas-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .area-card {
        background: rgba(0, 0, 0, 0.4);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 2rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }
    
    .area-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-accent);
        transform: scaleX(0);
        transition: transform 0.3s ease;
    }
    
    .area-card:hover {
        border-color: var(--accent-cyan);
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 15px 35px rgba(0, 180, 216, 0.3);
    }
    
    .area-card:hover::before {
        transform: scaleX(1);
    }
    
    .area-card.selected {
        background: linear-gradient(145deg, rgba(0, 180, 216, 0.2), rgba(0, 119, 182, 0.1));
        border-color: var(--accent-cyan);
        box-shadow: 0 15px 35px rgba(0, 180, 216, 0.4);
    }
    
    .area-card.selected::before {
        transform: scaleX(1);
    }
    
    .area-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        color: var(--accent-cyan);
        transition: all 0.3s ease;
    }
    
    .area-card:hover .area-icon,
    .area-card.selected .area-icon {
        transform: scale(1.1) rotate(5deg);
        color: #ffffff;
    }
    
    .area-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-color);
        margin-bottom: 0.5rem;
    }
    
    .area-description {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.4;
    }
    
    .area-checkbox {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }
    
    /* Custom Range Sliders */
    .slider-container {
        margin-bottom: 2rem;
    }
    
    .slider-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        font-weight: 600;
        color: var(--text-color);
    }
    
    .slider-value {
        background: var(--gradient-accent);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 15px;
        font-weight: 700;
        min-width: 80px;
        text-align: center;
    }
    
    .custom-slider {
        width: 100%;
        height: 8px;
        border-radius: 5px;
        background: rgba(255, 255, 255, 0.1);
        outline: none;
        opacity: 0.8;
        transition: opacity 0.3s;
        appearance: none;
        margin-bottom: 1rem;
    }
    
    .custom-slider:hover {
        opacity: 1;
    }
    
    .custom-slider::-webkit-slider-thumb {
        appearance: none;
        width: 25px;
        height: 25px;
        border-radius: 50%;
        background: var(--gradient-accent);
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(0, 180, 216, 0.4);
        transition: all 0.3s ease;
    }
    
    .custom-slider::-webkit-slider-thumb:hover {
        transform: scale(1.2);
        box-shadow: 0 6px 20px rgba(0, 180, 216, 0.6);
    }
    
    .custom-slider::-moz-range-thumb {
        width: 25px;
        height: 25px;
        border-radius: 50%;
        background: var(--gradient-accent);
        cursor: pointer;
        border: none;
        box-shadow: 0 4px 15px rgba(0, 180, 216, 0.4);
    }
    
    .slider-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.95rem;
    }
    
    .slider-info i {
        color: var(--accent-cyan);
    }
    
    /* Seção de Opções */
    .options-section {
        background: rgba(0, 0, 0, 0.3);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .options-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text-color);
        margin-bottom: 1.5rem;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }
    
    .option-buttons {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }
    
    .option-card {
        background: rgba(0, 0, 0, 0.4);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 2rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    
    .option-card.selected {
        border-color: var(--accent-cyan);
        background: linear-gradient(145deg, rgba(0, 180, 216, 0.2), rgba(0, 119, 182, 0.1));
        transform: scale(1.02);
        box-shadow: 0 10px 25px rgba(0, 180, 216, 0.3);
    }
    
    .option-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-cyan);
    }
    
    .option-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        transition: all 0.3s ease;
    }
    
    .option-card.selected .option-icon,
    .option-card:hover .option-icon {
        transform: scale(1.1);
    }
    
    .option-now .option-icon {
        color: var(--success-color);
    }
    
    .option-schedule .option-icon {
        color: var(--accent-purple);
    }
    
    .option-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-color);
        margin-bottom: 0.5rem;
    }
    
    .option-description {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.95rem;
        line-height: 1.4;
    }
    
    /* DateTime Input */
    .datetime-container {
        position: relative;
        margin-top: 1.5rem;
        opacity: 0;
        max-height: 0;
        overflow: hidden;
        transition: all 0.4s ease;
    }
    
    .datetime-container.active {
        opacity: 1;
        max-height: 200px;
    }
    
    .datetime-input {
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 15px;
        color: white;
        padding: 1rem 1.5rem;
        font-size: 1.1rem;
        width: 100%;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }
    
    .datetime-input:focus {
        background: rgba(0, 0, 0, 0.8);
        border-color: var(--accent-cyan);
        box-shadow: 0 0 0 4px rgba(0, 180, 216, 0.2);
        outline: none;
    }
    
    .datetime-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255, 255, 255, 0.8);
        margin-top: 1rem;
        font-size: 0.95rem;
    }
    
    .datetime-info i {
        color: var(--accent-cyan);
    }
    
    /* Action Buttons */
    .form-actions {
        display: flex;
        justify-content: space-between;
        margin-top: 3rem;
        gap: 2rem;
    }
    
    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 1rem 2rem;
        border-radius: 15px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .btn-cancel:hover {
        background: rgba(220, 53, 69, 0.2);
        border-color: var(--danger-color);
        color: white;
        transform: translateY(-2px);
    }
    
    .btn-submit {
        border: none;
        color: white;
        padding: 1rem 3rem;
        border-radius: 15px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
    }

    .btn-submit.now-mode {
        background: var(--gradient-success);
    }
    
    .btn-submit.schedule-mode {
        background: var(--gradient-purple);
    }

    .btn-submit::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.6s;
    }
    
    .btn-submit:hover::before {
        left: 100%;
    }
    
    .btn-submit.now-mode:hover {
        background: linear-gradient(135deg, #20c997, #28a745);
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 15px 35px rgba(40, 167, 69, 0.5);
    }
    
    .btn-submit.schedule-mode:hover {
        background: linear-gradient(135deg, #7e25e3, #9b59b6);
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 15px 35px rgba(108, 19, 211, 0.5);
    }
    
    .btn-submit:disabled {
        background: rgba(108, 19, 211, 0.5) !important;
        cursor: not-allowed;
        transform: none !important;
    }
    
    /* Tips Section */
    .tips-section {
        background: var(--gradient-card);
        border: 1px solid rgba(0, 180, 216, 0.3);
        border-radius: 25px;
        backdrop-filter: blur(20px);
        box-shadow: 
            0 20px 40px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        overflow: hidden;
        animation: fadeInUp 0.8s ease-out 0.8s both;
        position: relative;
    }
    
    .tips-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-purple);
        opacity: 0.9;
    }
    
    .tips-header {
        background: rgba(108, 19, 211, 0.2);
        border-bottom: 1px solid rgba(108, 19, 211, 0.3);
        padding: 2rem;
    }
    
    .tips-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-color);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .tips-title i {
        color: var(--accent-purple);
        font-size: 1.6rem;
    }
    
    .tips-content {
        padding: 2rem;
    }
    
    .tips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }
    
    .tip-card {
        display: flex;
        gap: 1.5rem;
        padding: 1.5rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 15px;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .tip-card:hover {
        background: rgba(108, 19, 211, 0.1);
        transform: translateY(-3px);
    }
    
    .tip-icon {
        flex-shrink: 0;
        width: 60px;
        height: 60px;
        background: var(--gradient-purple);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        transition: all 0.3s ease;
    }
    
    .tip-card:hover .tip-icon {
        transform: scale(1.1) rotate(5deg);
    }
    
    .tip-content {
        flex: 1;
    }
    
    .tip-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-color);
        margin-bottom: 0.5rem;
    }
    
    .tip-description {
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.5;
        font-size: 0.95rem;
    }
    
    /* Animations */
    @keyframes slideInDown {
        from {
            opacity: 0;
            transform: translateY(-50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.8;
            transform: scale(1.05);
        }
    }
    
    /* Responsiveness */
    @media (max-width: 768px) {
        .agendar-simulado {
            padding: 0 0.5rem;
        }
        
        .page-header {
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }
        
        .page-title {
            font-size: 2rem;
        }
        
        .form-body {
            padding: 2rem 1.5rem;
        }
        
        .areas-grid {
            grid-template-columns: 1fr;
        }
        
        .option-buttons {
            grid-template-columns: 1fr;
        }
        
        .progress-indicator {
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        
        .progress-step {
            width: 40px;
            height: 40px;
            font-size: 0.9rem;
        }
        
        .tips-grid {
            grid-template-columns: 1fr;
        }
        
        .form-actions {
            flex-direction: column;
            gap: 1rem;
        }
        
        .btn-submit,
        .btn-cancel {
            width: 100%;
            justify-content: center;
        }
        
        .tip-card {
            flex-direction: column;
            text-align: center;
        }
        
        .tips-header,
        .tips-content {
            padding: 1.5rem;
        }
    }
    
    @media (max-width: 480px) {
        .page-title {
            font-size: 1.75rem;
        }
        
        .page-subtitle {
            font-size: 1.1rem;
        }
        
        .form-body {
            padding: 1.5rem 1rem;
        }
        
        .section-title {
            font-size: 1.4rem;
        }
        
        .area-card {
            padding: 1.5rem;
        }
        
        .area-icon {
            font-size: 2.5rem;
        }
    }
    
    /* Loading States */
    .loading {
        opacity: 0.7;
        pointer-events: none;
        position: relative;
    }
    
    .loading::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 30px;
        height: 30px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: var(--accent-cyan);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
        0% { transform: translate(-50%, -50%) rotate(0deg); }
        100% { transform: translate(-50%, -50%) rotate(360deg); }
    }

    /* Alert feedback */
    .alert-feedback {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        min-width: 300px;
        border-radius: 15px;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 180, 216, 0.3);
        animation: slideInRight 0.3s ease-out;
    }
</style>

<div class="agendar-simulado">
    <!-- Header -->
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-calendar-plus"></i>
            Simulado Personalizado
        </h1>
        <a href="{{ url_for('simulados.index') }}" class="back-btn">
            <i class="bi bi-arrow-left"></i>
            Voltar para Simulados
        </a>
    </div>
    
    <p class="page-subtitle">
        🎯 Configure seu simulado personalizado escolhendo áreas, quantidade de questões e duração.<br>
