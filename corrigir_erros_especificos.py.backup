# corrigir_arquivos_json_final.py
"""
Correção final dos arquivos JSON problemáticos
Foca especificamente em EspanholData.txt, InglesData.txt e LiteraturaData.txt
"""

import os
import re
import json
import psycopg2
from datetime import datetime

def limpar_texto_questao(texto):
    """Limpa e normaliza texto da questão"""
    if not texto:
        return ""
    
    # Remover aspas extras e escapes desnecessários
    texto = texto.strip()
    if texto.startswith('"') and texto.endswith('"'):
        texto = texto[1:-1]
    
    # Normalizar quebras de linha
    texto = texto.replace('\\n', ' ')
    texto = texto.replace('\n', ' ')
    texto = texto.replace('\r', ' ')
    
    # Remover espaços duplos
    texto = re.sub(r'\s+', ' ', texto)
    
    return texto.strip()

def extrair_questoes_com_regex_avancado(conteudo, nome_arquivo):
    """Extrai questões usando regex mais avançado"""
    
    questoes = []
    
    # Padrões específicos por arquivo
    if 'espanhol' in nome_arquivo.lower():
        # Espanhol tem padrão diferente
        pattern = r'\{\s*"question"\s*:\s*"([^"]*(?:\\.[^"]*)*)"[^}]*"answerA"\s*:\s*"([^"]*)"[^}]*"answerB"\s*:\s*"([^"]*)"[^}]*"answerC"\s*:\s*"([^"]*)"[^}]*"answerD"\s*:\s*"([^"]*)"[^}]*"answerE"\s*:\s*"([^"]*)"[^}]*"correctAnswer"\s*:\s*"([^"]*)"[^}]*"correctAnswermessage"\s*:\s*"([^"]*(?:\\.[^"]*)*)"'
    else:
        # Padrão geral
        pattern = r'\{\s*"question"\s*:\s*"([^"]*(?:\\.[^"]*)*)".*?"answerA"\s*:\s*"([^"]*)".*?"answerB"\s*:\s*"([^"]*)".*?"answerC"\s*:\s*"([^"]*)".*?"answerD"\s*:\s*"([^"]*)".*?"answerE"\s*:\s*"([^"]*)".*?"correctAnswer"\s*:\s*"([^"]*)".*?"correctAnswermessage"\s*:\s*"([^"]*(?:\\.[^"]*)*)"'
    
    matches = re.findall(pattern, conteudo, re.DOTALL | re.IGNORECASE)
    
    for match in matches:
        if len(match) >= 8:
            questao = {
                'question': limpar_texto_questao(match[0]),
                'answerA': limpar_texto_questao(match[1]),
                'answerB': limpar_texto_questao(match[2]),
                'answerC': limpar_texto_questao(match[3]),
                'answerD': limpar_texto_questao(match[4]),
                'answerE': limpar_texto_questao(match[5]),
                'correctAnswer': match[6].strip().upper(),
                'correctAnswermessage': limpar_texto_questao(match[7])
            }
            
            # Validar questão
            if (questao['question'] and 
                questao['correctAnswer'] in ['A', 'B', 'C', 'D', 'E'] and
                questao['answerA']):
                questoes.append(questao)
    
    return questoes

def extrair_questoes_linha_por_linha(conteudo):
    """Extrai questões processando linha por linha"""
    
    questoes = []
    questao_atual = {}
    dentro_de_questao = False
    chaves_abertas = 0
    
    linhas = conteudo.split('\n')
    
    for linha in linhas:
        linha = linha.strip()
        
        # Contar chaves
        chaves_abertas += linha.count('{') - linha.count('}')
        
        if '{' in linha and not dentro_de_questao:
            dentro_de_questao = True
            questao_atual = {}
        
        if dentro_de_questao:
            # Extrair campos usando regex simples
            if '"question"' in linha:
                match = re.search(r'"question"\s*:\s*"([^"]*(?:\\.[^"]*)*)"', linha)
                if match:
                    questao_atual['question'] = limpar_texto_questao(match.group(1))
            
            elif '"answerA"' in linha:
                match = re.search(r'"answerA"\s*:\s*"([^"]*)"', linha)
                if match:
                    questao_atual['answerA'] = limpar_texto_questao(match.group(1))
            
            elif '"answerB"' in linha:
                match = re.search(r'"answerB"\s*:\s*"([^"]*)"', linha)
                if match:
                    questao_atual['answerB'] = limpar_texto_questao(match.group(1))
            
            elif '"answerC"' in linha:
                match = re.search(r'"answerC"\s*:\s*"([^"]*)"', linha)
                if match:
                    questao_atual['answerC'] = limpar_texto_questao(match.group(1))
            
            elif '"answerD"' in linha:
                match = re.search(r'"answerD"\s*:\s*"([^"]*)"', linha)
                if match:
                    questao_atual['answerD'] = limpar_texto_questao(match.group(1))
            
            elif '"answerE"' in linha:
                match = re.search(r'"answerE"\s*:\s*"([^"]*)"', linha)
                if match:
                    questao_atual['answerE'] = limpar_texto_questao(match.group(1))
            
            elif '"correctAnswer"' in linha:
                match = re.search(r'"correctAnswer"\s*:\s*"([^"]*)"', linha)
                if match:
                    questao_atual['correctAnswer'] = match.group(1).strip().upper()
            
            elif '"correctAnswermessage"' in linha or '"correctAnswerMessage"' in linha:
                match = re.search(r'"correctAnswer[mM]essage"\s*:\s*"([^"]*(?:\\.[^"]*)*)"', linha)
                if match:
                    questao_atual['correctAnswermessage'] = limpar_texto_questao(match.group(1))
        
        # Fim da questão
        if dentro_de_questao and chaves_abertas == 0:
            dentro_de_questao = False
            
            # Validar e adicionar questão
            if (questao_atual.get('question') and 
                questao_atual.get('correctAnswer') in ['A', 'B', 'C', 'D', 'E'] and
                questao_atual.get('answerA')):
                questoes.append(questao_atual.copy())
            
            questao_atual = {}
    
    return questoes

def processar_arquivo_problematico(caminho_arquivo):
    """Processa arquivo JSON com problemas usando múltiplas estratégias"""
    
    nome_arquivo = os.path.basename(caminho_arquivo)
    print(f"\n🔧 PROCESSANDO: {nome_arquivo}")
    print("=" * 50)
    
    # Ler arquivo
    try:
        with open(caminho_arquivo, 'r', encoding='utf-8') as f:
            conteudo = f.read()
        print(f"✅ Arquivo lido: {len(conteudo)} caracteres")
    except Exception as e:
        print(f"❌ Erro ao ler arquivo: {e}")
        return []
    
    questoes_extraidas = []
    
    # Estratégia 1: JSON direto (improvável que funcione)
    try:
        dados = json.loads(conteudo)
        if isinstance(dados, list):
            questoes_extraidas = dados
        else:
            questoes_extraidas = [dados]
        print(f"✅ JSON direto funcionou: {len(questoes_extraidas)} questões")
    except:
        print("⚠️ JSON direto falhou, tentando alternativas...")
        
        # Estratégia 2: Regex avançado
        try:
            questoes_regex = extrair_questoes_com_regex_avancado(conteudo, nome_arquivo)
            if questoes_regex:
                questoes_extraidas = questoes_regex
                print(f"✅ Regex avançado: {len(questoes_extraidas)} questões")
        except Exception as e:
            print(f"⚠️ Regex avançado falhou: {e}")
        
        # Estratégia 3: Linha por linha
        if not questoes_extraidas:
            try:
                questoes_linha = extrair_questoes_linha_por_linha(conteudo)
                if questoes_linha:
                    questoes_extraidas = questoes_linha
                    print(f"✅ Linha por linha: {len(questoes_extraidas)} questões")
            except Exception as e:
                print(f"⚠️ Linha por linha falhou: {e}")
        
        # Estratégia 4: Extrair objetos JSON individuais
        if not questoes_extraidas:
            try:
                # Encontrar todos os blocos que parecem objetos JSON
                pattern = r'\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}'
                matches = re.findall(pattern, conteudo, re.DOTALL)
                
                questoes_objetos = []
                for match in matches:
                    try:
                        obj = json.loads(match.strip())
                        if obj.get('question') and obj.get('correctAnswer'):
                            questoes_objetos.append(obj)
                    except:
                        continue
                
                if questoes_objetos:
                    questoes_extraidas = questoes_objetos
                    print(f"✅ Objetos individuais: {len(questoes_extraidas)} questões")
                    
            except Exception as e:
                print(f"⚠️ Objetos individuais falhou: {e}")
    
    # Mostrar amostra
    if questoes_extraidas:
        print(f"\n📋 AMOSTRA DAS QUESTÕES:")
        for i, q in enumerate(questoes_extraidas[:2], 1):
            texto = q.get('question', '')[:80]
            resposta = q.get('correctAnswer', '')
            print(f"   {i}. {texto}... (Resp: {resposta})")
    
    return questoes_extraidas

def inserir_questoes_no_banco(questoes, materia):
    """Insere questões no banco PostgreSQL"""
    
    if not questoes:
        return 0
    
    conn = psycopg2.connect(
        host='localhost',
        user='postgres',
        password='1469',
        database='launcher_db'
    )
    
    cursor = conn.cursor()
    inseridas = 0
    duplicatas = 0
    erros = 0
    
    try:
        for questao in questoes:
            try:
                # Verificar duplicata
                cursor.execute("""
                    SELECT id FROM questoes_base 
                    WHERE texto = %s AND materia = %s
                """, (questao.get('question', ''), materia))
                
                if cursor.fetchone():
                    duplicatas += 1
                    continue
                
                # Inserir questão
                cursor.execute("""
                    INSERT INTO questoes_base (
                        texto, materia, topico, opcao_a, opcao_b, opcao_c, opcao_d, opcao_e,
                        resposta_correta, explicacao, dificuldade, ativa, data_criacao
                    ) VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                """, (
                    questao.get('question', ''),
                    materia,
                    questao.get('topico', ''),
                    questao.get('answerA', ''),
                    questao.get('answerB', ''),
                    questao.get('answerC', ''),
                    questao.get('answerD', ''),
                    questao.get('answerE', ''),
                    questao.get('correctAnswer', 'A'),
                    questao.get('correctAnswermessage', questao.get('correctAnswerMessage', '')),
                    0.5,  # dificuldade padrão
                    True,
                    datetime.now()
                ))
                
                inseridas += 1
                
            except Exception as e:
                erros += 1
                print(f"   ❌ Erro ao inserir questão: {e}")
                continue
        
        conn.commit()
        
        print(f"\n📊 RESULTADO:")
        print(f"   Inseridas: {inseridas}")
        print(f"   Duplicatas: {duplicatas}")
        print(f"   Erros: {erros}")
        
        return inseridas
        
    finally:
        cursor.close()
        conn.close()

def processar_todos_arquivos_problemáticos():
    """Processa todos os arquivos que deram problema"""
    
    arquivos_problema = [
        ('EspanholData.txt', 'Espanhol'),
        ('InglesData.txt', 'Inglês'),
        ('LiteraturaData.txt', 'Literatura')
    ]
    
    total_recuperadas = 0
    
    for arquivo, materia in arquivos_problema:
        if os.path.exists(arquivo):
            print(f"\n{'='*60}")
            print(f"PROCESSANDO: {arquivo} ({materia})")
            print("="*60)
            
            questoes = processar_arquivo_problematico(arquivo)
            
            if questoes:
                inseridas = inserir_questoes_no_banco(questoes, materia)
                total_recuperadas += inseridas
                print(f"✅ {inseridas} questões de {materia} inseridas!")
            else:
                print(f"❌ Nenhuma questão extraída de {arquivo}")
        else:
            print(f"⚠️ Arquivo {arquivo} não encontrado")
    
    return total_recuperadas

def verificar_resultado_final():
    """Verifica o resultado final após correções"""
    
    print(f"\n{'='*60}")
    print("VERIFICAÇÃO FINAL")
    print("="*60)
    
    try:
        conn = psycopg2.connect(
            host='localhost',
            user='postgres',
            password='1469',
            database='launcher_db'
        )
        
        cursor = conn.cursor()
        
        # Total geral
        cursor.execute("SELECT COUNT(*) FROM questoes_base WHERE ativa = true")
        total = cursor.fetchone()[0]
        
        # Por matéria
        cursor.execute("""
            SELECT materia, COUNT(*) 
            FROM questoes_base 
            WHERE ativa = true 
            GROUP BY materia 
            ORDER BY COUNT(*) DESC
        """)
        
        por_materia = cursor.fetchall()
        
        print(f"📊 RESULTADO FINAL:")
        print(f"   Total de questões: {total}")
        print(f"   Matérias: {len(por_materia)}")
        
        print(f"\n📚 POR MATÉRIA:")
        for materia, count in por_materia:
            print(f"   {materia}: {count} questões")
        
        # Capacidade de simulados
        simulados_enem = total // 180
        print(f"\n🎯 CAPACIDADE:")
        print(f"   Simulados ENEM possíveis: ~{simulados_enem}")
        print(f"   Simulados 45 questões: ~{total // 45}")
        
        cursor.close()
        conn.close()
        
    except Exception as e:
        print(f"❌ Erro na verificação: {e}")

def main():
    """Função principal"""
    print("🔧 CORREÇÃO FINAL DOS ARQUIVOS JSON PROBLEMÁTICOS")
    print("="*60)
    print("Recuperando questões de Espanhol, Inglês e Literatura\n")
    
    # Processar arquivos
    total_recuperadas = processar_todos_arquivos_problemáticos()
    
    # Verificar resultado
    verificar_resultado_final()
    
    print(f"\n{'='*60}")
    print("RESULTADO DA CORREÇÃO")
    print("="*60)
    
    if total_recuperadas > 0:
        print(f"🎉 SUCESSO! {total_recuperadas} questões recuperadas!")
        print("\nAgora você tem ainda mais questões para seus simulados!")
        print("Execute o script de integração para finalizar:")
        print("   python integrar_questoes_sistema.py")
    else:
        print("⚠️ Nenhuma questão nova foi recuperada")
        print("Mas seu sistema já está funcionando com as questões existentes!")
    
    print(f"\n🚀 PRÓXIMOS PASSOS:")
    print(f"   1. Testar interface: /agendar-simulado/")
    print(f"   2. Criar simulados com diferentes matérias")
    print(f"   3. Verificar explicações nos resultados")

if __name__ == "__main__":
    main()